# --- Pexels ---
PEXELS_API_KEY=tu_api_key_aqui

# --- Proveedor de IA ---
# Valores soportados:
#   ollama  → único proveedor implementado actualmente.
#   gemini  → reservado, aún no implementado (ver issue futuro).
#   openai  → reservado, aún no implementado (ver issue futuro).
AI_PROVIDER=ollama

# --- Ollama (cuando AI_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# --- Gemini (placeholder, aún no funcional) ---
# GEMINI_API_KEY=tu_api_key_aqui
# GEMINI_MODEL=gemini-1.5-flash

# --- OpenAI (placeholder, aún no funcional) ---
